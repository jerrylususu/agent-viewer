{
  "profiles": [
    {
      "id": "claude",
      "displayName": "Claude Code",
      "command": "claude",
      "defaultArgs": [
        "--chrome",
        "--dangerously-skip-permissions"
      ],
      "detect": {
        "processRegex": "(?:^|/)claude(?:\\s|$)"
      },
      "readiness": {
        "type": "prompt_regex",
        "pattern": "^>\\s*$|^❯\\s*$|^❯\\s+\\S",
        "timeoutMs": 30000,
        "autoDismissClaudePrompts": true
      },
      "status": {
        "mode": "heuristic",
        "filePathTemplate": "${projectPath}/.agent-status.json"
      },
      "env": {},
      "systemInitPrompt": ""
    },
    {
